# ══════════════════════════════════════════════════════════════════
# BMG SaaS Platform — .gitignore
# ══════════════════════════════════════════════════════════════════

# ── Environment files ─────────────────────────────────────────────
.env
.env.*
.env.example          # KEEP the example — never keep real values
*.env

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# ── Django ────────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/
media/

# ── Virtual environments ──────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Testing ───────────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
coverage.xml
*.cover
nosetests.xml

# ── IDE / editors ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Celery ────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Generated files ───────────────────────────────────────────────
schema.yaml            # regenerated by CI: python manage.py spectacular
schema.graphql         # regenerated by CI: python manage.py graphql_schema

# ── Secrets (NEVER commit these) ─────────────────────────────────
*.pem
*.key
*.p12
*.pfx
secrets/
