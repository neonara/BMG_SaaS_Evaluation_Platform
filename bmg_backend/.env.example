# ── Django ────────────────────────────────────────────────────────
SECRET_KEY=change-me-min-50-chars
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=app.bmg.tn,api.bmg.tn
DEBUG=False

# ── Database (django-tenants) ────────────────────────────────────
DATABASE_URL=postgres://bmg_user:password@postgres:5432/bmg_public
POSTGRES_USER=bmg_user
POSTGRES_PASSWORD=your-postgres-password

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://:your-redis-password@redis:6379/0

# ── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_URL=amqp://bmg_user:password@rabbitmq:5672/bmg

# ── Email ────────────────────────────────────────────────────────
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=no-reply@bmg.tn
SMTP_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=BMG Platform <no-reply@bmg.tn>

# ── External services ────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
GOTENBERG_URL=http://gotenberg:3001
SELENIUM_URL=http://selenium_grid:4444/wd/hub

# ── Payment gateways ─────────────────────────────────────────────
KONNECT_API_KEY=
CLICTOPAY_MERCHANT_ID=
CLICTOPAY_PASSWORD=
PAYMEE_API_KEY=

# ── Frontend ─────────────────────────────────────────────────────
FRONTEND_URL=https://app.bmg.tn
VITRINE_URL=https://bmg.tn

# ── Sentry (optional) ────────────────────────────────────────────
SENTRY_DSN=
